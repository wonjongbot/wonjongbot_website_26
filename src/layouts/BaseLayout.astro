---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title} | WonjongBot</title>
		<meta name="title" content={`${title} | WonjongBot`} />
		<meta name="description" content="WonjongBot's Portfolio - Computer Engineering at UIUC. Interests in Computer Architecture and Design Verification." />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="WonjongBot's Portfolio - Computer Engineering at UIUC. Interests in Computer Architecture and Design Verification." />
		<meta property="og:image" content={new URL('/images/profile.jpg', Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="WonjongBot's Portfolio - Computer Engineering at UIUC. Interests in Computer Architecture and Design Verification." />
		<meta property="twitter:image" content={new URL('/images/profile.jpg', Astro.url)} />
	</head>
	<body>
		<div class="container">
			<header>
				<nav style="margin-bottom: 40px; border-bottom: 1px solid black; padding-bottom: 10px;">
					<a href="/" style="font-weight: bold; font-size: 1.2em; text-decoration: none; margin-right: 20px;">wonjongbot</a>
					<a href="/projects">Projects</a>
                    <span style="margin: 0 10px;">|</span>
                    <a href="/cv">CV</a>
					<span style="margin: 0 10px;">|</span>
					<a href="/posts">Posts</a>
				</nav>
			</header>
			<slot />
			<footer style="margin-top: 80px; border-top: 1px solid black; padding-top: 20px; font-size: 0.8em; color: #666;">
				<p>&copy; {new Date().getFullYear()} WonjongBot.</p>
			</footer>
		</div>
	</body>
</html>
