---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('posts');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title}>
    <main>
        <nav class="subpage-nav">
             <a href="/posts">&lt; DIRECTORY UP (POSTS)</a>
        </nav>
        
        <header class="post-header">
            <h1>{entry.data.title}</h1>
            <!--<div class="post-meta">
                WRITTEN BY {entry.data.author.toUpperCase()} ON {entry.data.pubDate.toISOString().slice(0,10)}
            </div>-->
        </header>

        <!--<div class="hr-solid"></div>-->

        <div class="blog-content">
            <Content />
        </div>
        
        <div class="hr-solid"></div>
        <a href="#">TOP OF FILE</a>
    </main>
</BaseLayout>

<style is:global>
    .subpage-nav { margin-bottom: var(--v-gap); font-family: var(--font-mono); font-size: 0.9em; }
    .post-header h1 { margin-top: var(--v-gap-small); margin-bottom: var(--v-gap-small); font-family: var(--font-serif); }
    .post-meta { font-family: var(--font-mono); font-size: 0.85em; margin-bottom: var(--v-gap); color: #555; }

    /* Raw Markdown Styling Override */
    .blog-content { font-family: var(--font-serif); line-height: 1.6; }
    .blog-content h1 { font-size: 1.8rem; border-bottom: none; font-family: var(--font-serif); }
    .blog-content h2 { font-size: 1.5rem; border-bottom: 1px dotted #000; margin-top: 2em; font-family: var(--font-serif); }
    .blog-content p, .blog-content li { font-family: var(--font-serif); }
    .blog-content ul, .blog-content ol { margin-bottom: 1em; padding-left: 1.5em; }
    .blog-content blockquote {
        margin: 1em 0;
        padding-left: 20px;
        border-left: 4px solid var(--border-color);
        background: #f9f9f9;
        font-family: var(--font-serif);
        font-style: italic;
    }
    .blog-content code, .blog-content pre {
        font-family: var(--font-mono);
    }
    .blog-content img {
        max-width: 100%;
        border: 1px solid black;
        margin: var(--v-gap) 0;
    }
</style>
