---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "CV";
// User can replace this with their Overleaf read-only PDF link
// Pattern: https://www.overleaf.com/read/<TOKEN>/output.pdf
const cvPdfUrl = "/cv.pdf"; 
---

<BaseLayout title={pageTitle}>
    <main>
        <h1>Curriculum Vitae</h1>
        <div class="hr-solid"></div>
        
        <div class="cv-controls">
            <a href={cvPdfUrl} target="_blank" rel="noopener noreferrer">[ OPEN PDF IN NEW TAB ]</a>
        </div>

        <div class="pdf-container">
            <iframe 
                src={`${cvPdfUrl}#view=FitH`} 
                width="100%" 
                height="1100px" 
                style="border: 2px solid black;"
            >
                <p>It appears you don't have a PDF plugin for this browser. No biggie... you can <a href={cvPdfUrl}>click here to download the PDF file.</a></p>
            </iframe>
        </div>
    </main>
</BaseLayout>

<style>
    .cv-controls {
        margin-bottom: var(--v-gap);
        font-family: var(--font-serif);
    }
    .brutalist-link {
        font-weight: bold;
        text-decoration: underline;
        color: black;
    }
    .brutalist-link:hover {
        background: black;
        color: white;
        text-decoration: none;
    }
    .small {
        font-size: 0.8em;
        margin-top: 5px;
        color: #666;
    }
    .pdf-container {
        margin-top: var(--v-gap);
        box-shadow: 10px 10px 0px #eee;
    }
</style>
